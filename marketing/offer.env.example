# Copy this file to .env.local in the repo root.
# Do not commit .env.local. It is ignored by git.

# Paid product checkout
PRODUCT_CHECKOUT_PROVIDER=PayPal
PRODUCT_PRICE=$14.90
PRODUCT_CURRENCY=USD
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_WEBHOOK_ID=
PAYPAL_MODE=sandbox

# Paid access infrastructure
# Defaults are fine unless the bucket name is already taken.
PROTECTED_BUCKET=deleg8-dev-laws-of-ai-protected
FIRESTORE_LOCATION=nam5

# Newsletter option A: use the action URL from Kit's embedded form.
# This is the cleanest static-site option if Kit gives you a complete form POST URL.
KIT_FORM_ACTION=
KIT_EMAIL_FIELD=email

# Newsletter option B: use Kit's legacy public v3 form subscribe API.
# KIT_V3_PUBLIC_API_KEY is public by design and may appear in the generated static HTML.
KIT_FORM_ID=
KIT_V3_PUBLIC_API_KEY=

# Kit V4 key for local/server-side automation only.
# This must never be written into static HTML. Deploy stores it in Secret Manager.
KIT_V4_API_KEY=

# Optional aliases if you use another provider later.
NEWSLETTER_FORM_ACTION=
NEWSLETTER_EMAIL_FIELD=email
